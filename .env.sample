# Telegram
TELEGRAM_BOT_TOKEN=

# MongoDB (required)
MONGODB_URI=

# CookMyBots AI Gateway (required)
# COOKMYBOTS_AI_ENDPOINT is a BASE URL (do NOT include /chat)
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=

# Optional controls
AI_DEBUG=0
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20

# Optional defaults
TZ=UTC
PORT=3000
BASE_URL=
